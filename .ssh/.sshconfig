Host kaisel
	User git
	HostName github.com
	PreferredAuthentications publickey
	IdentityFile /home/kaisel/.ssh/id_ed25519

Host osp2
        HostName localhost
        User root
        Port 2223
        PreferredAuthentications password
        PubkeyAuthentication no
        StrictHostKeyChecking no
        UserKnownHostsFile=/dev/null
